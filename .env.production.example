# ---------------------------------------------------------------------------
# .env.production.example
#
# Vorlage für die ENV-Variablen, die der Vercel-SSR-Deploy braucht
# (Code-Session 34).
#
# **Niemals echte Werte hier hineinschreiben** — die echten Werte
# kommen über `vercel env add` ins Vercel-Dashboard. Diese Datei ist
# nur die Liste der Variablen mit Beschreibung.
# ---------------------------------------------------------------------------

# ---- AI-Schicht: Auth-Pflicht ---------------------------------------------

# Bearer-Token für die /api/ai/*-Routen. Wird auch als Default für
# `LP_AI_PASSWORD` und `LP_AI_SESSION_SECRET` genommen, sofern beide
# nicht eigenständig gesetzt sind.
# Empfehlung: ≥ 32 Zeichen, generiert via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LP_AI_API_KEY=

# Login-Passwort für den Cookie-Session-Pfad (siehe `<AuthCard>`).
# Wenn nicht gesetzt, fällt es auf `LP_AI_API_KEY` zurück. Für
# Production empfehlen wir ein eigenes Passwort, damit der gestohlene
# Bearer-Token nicht automatisch das Cookie-Login öffnet.
LP_AI_PASSWORD=

# HMAC-SHA256-Signing-Key für Cookie-JWTs. Mind. 32 Zeichen ASCII oder
# 256 Bit Random-Base64. Wenn nicht gesetzt, fällt es auf
# `LP_AI_API_KEY` zurück (nicht empfohlen für Production).
LP_AI_SESSION_SECRET=

# ---- AI-Schicht: Cost-Cap -------------------------------------------------

# Tagesbudget für KI-Aufrufe in USD (Default 1.00). Beim Überschreiten
# liefert /api/ai/generate 429 mit X-RateLimit-Reset-Header.
LP_AI_DAILY_CAP_USD=1.00

# ---- AI-Schicht: Live-Provider (alle optional) ----------------------------

# OpenAI: Bearer-Token aus dem OpenAI-Dashboard.
OPENAI_API_KEY=
# Override des Default-Modells (gpt-4o-mini). Optional.
OPENAI_MODEL=

# Anthropic: API-Key aus console.anthropic.com.
ANTHROPIC_API_KEY=
# Override des Default-Modells (claude-sonnet-4-5). Optional.
ANTHROPIC_MODEL=

# Gemini: API-Key aus aistudio.google.com.
GEMINI_API_KEY=
# Override des Default-Modells (gemini-2.0-flash). Optional.
GEMINI_MODEL=

# ---- AI-Schicht: Provider-Auswahl ----------------------------------------

# Default-Provider, wenn der Aufrufer keinen explizit setzt.
# Erlaubt: mock | openai | anthropic | gemini. Default: mock.
AI_PROVIDER=mock

# ---- Plattform-Betreiber-Daten (Pflicht vor Live-Schaltung, ab Session 36)
#
# Werden auf `/impressum` und `/datenschutz` der **Plattform** angezeigt
# (nicht für Demo-Betriebe — die haben ihre eigenen Daten in den Mocks).
# Persönliche Daten landen bewusst NIE im Repo, sondern nur hier in der
# Vercel-ENV. Solange leer, läuft die Plattform im "Demo-Mode" mit
# sichtbarem "Anbieter nicht konfiguriert"-Hinweis.

LP_OWNER_NAME=
LP_OWNER_STREET=
LP_OWNER_POSTAL_CODE=
LP_OWNER_CITY=
LP_OWNER_COUNTRY=Deutschland
LP_OWNER_EMAIL=

# Optional, aber empfohlen:
LP_OWNER_PHONE=
# USt-IdNr. nach § 27a UStG, falls vorhanden:
LP_OWNER_TAX_ID=

# ---- Datenbank: Supabase (optional, ab Code-Session 35) -------------------

# Wenn beide gesetzt sind, zeigt /api/ai/health im Block `database`
# einen Status `ok`/`degraded`/`offline` an. Ohne diese Variablen
# läuft die App weiter komplett im Mock-/Local-Storage-Modus —
# `database.status` ist dann `offline` mit Hinweis "nicht konfiguriert".
#
# Werte holen: Supabase-Dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-Role-Key (NUR server-side, NIE im Client!) — wird ab
# Multi-Tenant-Auth (Code-Session 36+) gebraucht. Bis dahin leer lassen.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Test-Flags (nur für Live-Smoketests, nicht in Production setzen!) ---
# LP_TEST_OPENAI_LIVE=1
# LP_TEST_ANTHROPIC_LIVE=1
# LP_TEST_GEMINI_LIVE=1
