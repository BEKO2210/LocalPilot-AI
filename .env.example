# LocalPilot AI – Beispiel-Umgebungsvariablen
# Diese Datei ist ein Beispiel. Kopiere sie als .env.local und fülle die Werte.
# Ohne API-Keys läuft das System automatisch im Mock-Modus.

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_NAME="LocalPilot AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================================
# AI Provider
# Werte: mock | openai | anthropic | gemini
# Ohne Key fällt das System automatisch auf "mock" zurück.
# ============================================================================
AI_PROVIDER="mock"

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# ============================================================================
# Supabase (wird ab Session 19 vorbereitet – im Moment optional)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
